# 브라우저에 노출되는 변수는 반드시 NEXT_PUBLIC_ 접두사
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 서버 전용 (클라이언트에 노출 안 됨)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=your_database_url
AUTH_SECRET=your_auth_secret

# Google AI (덱 추천 기능) — .env.local에만 추가, 절대 커밋하지 않음
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key

# 로컬 LLM 백엔드 (챗봇 / 카운터 덱 추천) — 모델만 바꿔 자유롭게 테스트
LLM_BASE_URL=http://localhost:11434/api
LLM_CHAT_MODEL=qwen2.5:7b
LLM_DECK_MODEL=qwen2.5:7b
